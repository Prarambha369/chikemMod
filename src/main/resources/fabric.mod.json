{
  "schemaVersion": 1,
  "id": "chikem-mod",
  "version": "${version}",
  "name": "Chikem Mod",
  "description": "Adds Special Chickems, difficulty-based breeding chances, and treasure loot for GolChick Food + Goldie Egg.",
  "authors": [
    "Prarambha369"
  ],
  "contact": {
    "homepage": "https://github.com/Prarambha369/chikemMod",
    "sources": "https://github.com/Prarambha369/chikemMod",
    "issues": "https://github.com/Prarambha369/chikemMod/issues"
  },
  "license": "MIT",
  "icon": "assets/CHICKEMMOD.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "mr.bashyal.chikemmod.ChikemMod"
    ],
    "client": [
      "mr.bashyal.chikemmod.client.ChickenmodClient"
    ]
  },
  "mixins": [
    "chikem-mod.mixins.json",
    {
      "config": "chikemmod.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.18.1",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": "*"
  }
}